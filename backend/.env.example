# Backend Environment Variables
# Copy file ini ke .env dan isi sesuai konfigurasi hosting

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Untuk production (MySQL di Dewaweb):
DATABASE_URL="mysql://USERNAME:PASSWORD@localhost:3306/NAMA_DATABASE"

# Untuk development (SQLite lokal):
# DATABASE_URL="file:../prisma/dev.db"

# ─── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET="ganti-dengan-string-random-minimal-32-karakter-yang-sangat-rahasia"

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# URL frontend (untuk CORS) - ganti dengan domain asli
FRONTEND_URL="https://monitoring.bpsppu.com"

# ─── PENGATURAN APLIKASI (opsional, bisa diatur via Admin > Settings) ────────
APP_NAME="Monitoring SE2026 PPU"
EWS_THRESHOLD_HARI=2
PERIODE_MULAI="2026-06-15"
PERIODE_SELESAI="2026-08-31"
