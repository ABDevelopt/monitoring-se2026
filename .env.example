# ============================================================
# MONITORING SE2026 — KABUPATEN PENAJAM PASER UTARA
# Salin file ini menjadi .env.local dan isi nilainya
# ============================================================

# --- Database MySQL ---
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/monitoring_se2026"

# --- NextAuth.js ---
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-random-string-panjang"

# URL aplikasi (tanpa trailing slash)
# Development : http://localhost:3000
# Production  : https://domain-anda.com
NEXTAUTH_URL="http://localhost:3000"

# --- Environment ---
NODE_ENV="development"

# --- Konfigurasi Aplikasi ---
# Threshold EWS: jumlah hari tanpa laporan sebelum trigger alert
EWS_THRESHOLD_HARI=2

# Nama aplikasi (tampil di header & title)
APP_NAME="Monitoring SE2026 PPU"

# Periode pendataan (format: YYYY-MM-DD)
PERIODE_MULAI="2026-06-15"
PERIODE_SELESAI="2026-08-31"
